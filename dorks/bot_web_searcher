import time
import csv
from selenium import webdriver
from selenium.webdriver.chrome.options import Options
from selenium.webdriver.common.by import By

# Configuración de Chrome headless
def create_driver():
    options = Options()
    options.add_argument("--headless")
    options.add_argument("--disable-gpu")
    options.add_argument("--no-sandbox")
    options.add_argument("--log-level=3")  # Minimiza logs
    driver = webdriver.Chrome(options=options)
    return driver

# Carga dorks desde archivo
def load_dorks(file_path):
    with open(file_path, 'r', encoding='utf-8') as f:
        return [line.strip() for line in f if line.strip()]

# Buscar en Google y extraer URLs de resultados
def search_dork(driver, dork):
    driver.get("https://www.google.com")
    time.sleep(2)

    # Encontrar caja de búsqueda
    search_box = driver.find_element(By.NAME, "q")
    search_box.clear()
    search_box.send_keys(dork)
    search_box.submit()

    time.sleep(3)  # Esperar carga resultados

    # Extraer URLs de resultados en la primera página
    urls = []
    results = driver.find_elements(By.CSS_SELECTOR, 'div.yuRUbf > a')
    for r in results:
        url = r.get_attribute('href')
        if url:
            urls.append(url)
    return urls

# Guardar resultados en CSV
def save_results(results, filename="results.csv"):
    with open(filename, mode='w', newline='', encoding='utf-8') as csvfile:
        writer = csv.writer(csvfile)
        writer.writerow(['dork', 'url'])
        for dork, urls in results.items():
            for url in urls:
                writer.writerow([dork, url])
    print(f"Resultados guardados en {filename}")

def main():
    driver = create_driver()
    dorks = load_dorks('dic_dork.txt')
    results = {}

    for dork in dorks:
        try:
            print(f"Buscando: {dork}")
            urls = search_dork(driver, dork)
            results[dork] = urls
            print(f"URLs encontradas: {len(urls)}")
        except Exception as e:
            print(f"Error con dork {dork}: {e}")

    driver.quit()
    save_results(results)

if __name__ == "__main__":
    main()
