# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=tu_token_de_telegram

# ── Google Generative AI ──────────────────────────────────────────────────────
GEMINI_API_KEY=tu_api_key_de_gemini

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Formato: postgresql+asyncpg://usuario:contraseña@host:puerto/nombre_db
DATABASE_URL=postgresql+asyncpg://insightflow:insightflow@localhost:5432/insightflow

# ── Paywall ───────────────────────────────────────────────────────────────────
FREE_MESSAGE_LIMIT=7

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080
# URL que usa el navegador para cargar /data/... (ngrok o dominio real). Ej: https://abc.ngrok-free.app
PUBLIC_BASE_URL=
# API Go → worker Python (local: http://localhost:8001 ; Docker: http://brain:8001)
WORKER_URL=http://localhost:8001
# Directorio compartido con el worker (PDFs, CSVs, gráficas). En Docker: /app/data
DATA_DIR=data
# false (recomendado): gráficas vía /download/:token; no expone /data. true: sirve /data en claro (solo dev).
ENABLE_PUBLIC_DATA=false

# ── Seguridad HTTP (producción) ───────────────────────────────────────────────
# Orígenes permitidos para fetch desde el widget (coma). Vacío = cualquier origen (solo dev/ngrok).
# CORS_ALLOWED_ORIGINS=https://powerups.com.co,https://www.powerups.com.co
#
# Orígenes que pueden embeber /dashboard en <iframe> (espacios). Vacío = solo mismo host que la API.
# Ej.: sitio WordPress donde está el widget.
# CSP_FRAME_ANCESTORS=https://powerups.com.co https://www.powerups.com.co
#
# Límite por IP en POST /chat y /chat/upload (token bucket). 0 = desactivar.
# CHAT_RATE_LIMIT_RPS=8
# CHAT_RATE_LIMIT_BURST=24
#
# Tamaño máximo de subida (MB) para /chat/upload.
# UPLOAD_MAX_MB=32
#
# Secreto compartido: POST /api/v1/billing/webhook exige X-Webhook-Secret o Authorization: Bearer …
# BILLING_WEBHOOK_SECRET=
#
# Secreto de eventos Wompi (Dashboard → Integración): valida X-Event-Checksum del webhook.
# WOMPI_EVENT_SECRET=
#
# Secreto de webhook Bold: valida X-Bold-Signature (HMAC-SHA256 del body crudo).
# BOLD_WEBHOOK_SECRET=
#
# Timeout peticiones al Brain (Python), segundos. Debe ser ≤ deadline del cliente Go.
# WORKER_REQUEST_TIMEOUT_SEC=330
